# Copy this file to .env and adjust values for your environment.
# All variables are optional — defaults are shown.

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.3

# ── NLI Verification ──────────────────────────────────────────────────────────
NLI_MODEL=cross-encoder/nli-deberta-v3-small
NLI_CONFIDENCE_THRESHOLD=0.65
NLI_BATCH_SIZE=8

# ── Corpus ────────────────────────────────────────────────────────────────────
CORPUS_MAX_ARTICLES=500
CORPUS_CHUNK_SIZE=200
CORPUS_CHUNK_OVERLAP=50

# ── Self-correction ───────────────────────────────────────────────────────────
MAX_CORRECTION_ITERATIONS=3
IMPROVEMENT_THRESHOLD=0.05

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=data/logs
LOG_ENABLED=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
